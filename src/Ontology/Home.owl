<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.example.org/home"
         xmlns="http://www.example.org/home#">

<owl:Ontology rdf:about="http://www.example.org/home"/>

<owl:ObjectProperty rdf:about="#locatedIn">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#canBePickedBy">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Robot"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targetLocation">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#appliesTo">
  <rdfs:domain rdf:resource="#Task"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#isBimanual">
  <rdfs:domain rdf:resource="#Robot"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#cleanlinessStatus">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#priorityLevel">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#isFragile">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasMaterial">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasWeight">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#requires">
  <rdfs:domain rdf:resource="#Task"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Room"/>
<owl:Class rdf:about="#Object"/>
<owl:Class rdf:about="#Robot"/>
<owl:Class rdf:about="#Task"/>

<owl:Class rdf:about="#Kitchen">
  <rdfs:subClassOf rdf:resource="#Room"/>
</owl:Class>

<owl:Class rdf:about="#Bathroom">
  <rdfs:subClassOf rdf:resource="#Room"/>
</owl:Class>

<owl:Class rdf:about="#LivingRoom">
  <rdfs:subClassOf rdf:resource="#Room"/>
</owl:Class>

<owl:Class rdf:about="#Bedroom">
  <rdfs:subClassOf rdf:resource="#Room"/>
</owl:Class>

<owl:Class rdf:about="#Dish">
  <rdfs:subClassOf rdf:resource="#Object"/>
</owl:Class>

<owl:Class rdf:about="#Clothing">
  <rdfs:subClassOf rdf:resource="#Object"/>
</owl:Class>

<owl:Class rdf:about="#ElectronicDevice">
  <rdfs:subClassOf rdf:resource="#Object"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#SimpleGripperRobot">
  <rdf:type rdf:resource="#Robot"/>
  <isBimanual rdf:datatype="xsd:boolean">false</isBimanual>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#BimanualRobot">
  <rdf:type rdf:resource="#Robot"/>
  <isBimanual rdf:datatype="xsd:boolean">true</isBimanual>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#plate">
  <rdf:type rdf:resource="#Dish"/>
  <locatedIn rdf:resource="#Kitchen"/>
  <canBePickedBy rdf:resource="#SimpleGripperRobot"/>
  <targetLocation rdf:resource="#Kitchen"/>
  <cleanlinessStatus rdf:datatype="xsd:string">dirty</cleanlinessStatus>
  <isFragile rdf:datatype="xsd:boolean">true</isFragile>
  <hasMaterial rdf:datatype="xsd:string">ceramic</hasMaterial>
  <hasWeight rdf:datatype="xsd:string">medium</hasWeight>
  <priorityLevel rdf:datatype="xsd:int">2</priorityLevel>
</owl:NamedIndividual>

<!-- ✅ NUEVO: cup en la cocina + pickable -->
<owl:NamedIndividual rdf:about="#cup">
  <rdf:type rdf:resource="#Dish"/>
  <locatedIn rdf:resource="#Kitchen"/>
  <targetLocation rdf:resource="#Kitchen"/>

  <!-- ✅ añadido: pickable por este robot -->
  <canBePickedBy rdf:resource="#SimpleGripperRobot"/>

  <cleanlinessStatus rdf:datatype="xsd:string">clean</cleanlinessStatus>
  <isFragile rdf:datatype="xsd:boolean">true</isFragile>
  <hasMaterial rdf:datatype="xsd:string">glass</hasMaterial>
  <hasWeight rdf:datatype="xsd:string">light</hasWeight>
  <priorityLevel rdf:datatype="xsd:int">1</priorityLevel>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#DeliverPlateToSink">
  <rdf:type rdf:resource="#Task"/>
  <appliesTo rdf:resource="#plate"/>
  <requires rdf:datatype="xsd:string">cleanlinessStatus=dirty</requires>
</owl:NamedIndividual>

</rdf:RDF>