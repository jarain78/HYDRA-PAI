<?xml version="1.0"?>
<robot name="mobile_base_with_dual_lifts" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =========================
       PARAMETERS (hard-coded)
       Base: 0.30 x 0.30 x 0.30 m
       Two front lift columns: 0.50 m tall each
       Wheels: hoverboard style
       ========================= -->

  <!-- MATERIALS -->
  <material name="aluminum">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>

  <material name="wheel_blue">
    <color rgba="0.10 0.45 0.95 1.0"/>
  </material>

  <material name="caster_gray">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.30 0.30"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.30 0.30"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.120" ixy="0.0" ixz="0.0" iyy="0.120" iyz="0.0" izz="0.120"/>
    </inertial>
  </link>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Keep as-is: base_link center at 0.21m above ground -->
    <origin xyz="0 0 0.21" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       FRONT DUAL LIFT SYSTEM
       ========================= -->

  <!-- LEFT COLUMN CARRIAGE -->
  <link name="lift_left_carriage">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.50"/>
      </geometry>
      <material name="aluminum"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="0.7"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="lift_left_prismatic" type="prismatic">
    <parent link="base_link"/>
    <child link="lift_left_carriage"/>
    <origin xyz="0.15 0.08 -0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.00" upper="0.40" effort="800" velocity="0.30"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <link name="lift_left_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.01"/>
      </geometry>
      <material name="aluminum"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="lift_left_mount_fixed" type="fixed">
    <parent link="lift_left_carriage"/>
    <child link="lift_left_mount"/>
    <origin xyz="0 0 0.50" rpy="0 0 0"/>
  </joint>

  <link name="jso800_left_base_frame"/>
  <joint name="jso800_left_base_fixed" type="fixed">
    <parent link="lift_left_mount"/>
    <child link="jso800_left_base_frame"/>
    <origin xyz="0.00 0.00 0.02" rpy="0 0 0"/>
  </joint>

  <!-- RIGHT COLUMN CARRIAGE -->
  <link name="lift_right_carriage">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.50"/>
      </geometry>
      <material name="aluminum"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.50"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="0.7"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="lift_right_prismatic" type="prismatic">
    <parent link="base_link"/>
    <child link="lift_right_carriage"/>
    <origin xyz="0.15 -0.08 -0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.00" upper="0.40" effort="800" velocity="0.30"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <link name="lift_right_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.01"/>
      </geometry>
      <material name="aluminum"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.08 0.01"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="lift_right_mount_fixed" type="fixed">
    <parent link="lift_right_carriage"/>
    <child link="lift_right_mount"/>
    <origin xyz="0 0 0.50" rpy="0 0 0"/>
  </joint>

  <link name="jso800_right_base_frame"/>
  <joint name="jso800_right_base_fixed" type="fixed">
    <parent link="lift_right_mount"/>
    <child link="jso800_right_base_frame"/>
    <origin xyz="0.00 0.00 0.02" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       MOBILE BASE WHEELS
       Hoverboard-style drive wheels + 4 caster wheels
       ========================= -->

  <!-- ========= DRIVE WHEELS (2) ========= -->
  <!-- Hoverboard wheel size: radius=0.11 (≈22cm diameter), length=0.06 -->
  <link name="wheel_left">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.11" length="0.06"/>
      </geometry>
      <material name="wheel_blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.11" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <!-- base_link at z=0.21; wheel center should be at z=0.11 => z_local = -0.10 -->
    <origin xyz="0.00 0.19 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.2" friction="0.5"/>
  </joint>

  <link name="wheel_right">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.11" length="0.06"/>
      </geometry>
      <material name="wheel_blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.11" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0.00 -0.19 -0.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.2" friction="0.5"/>
  </joint>

  <!-- ========= CASTER WHEELS (4) ========= -->
  <!-- Keep casters touching the ground. With base_link at z=0.21, caster radius=0.025 -> z_local = 0.025 - 0.21 = -0.185 -->
  <link name="caster_fl">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="caster_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="caster_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_fl"/>
    <origin xyz="0.125 0.125 -0.185" rpy="0 0 0"/>
  </joint>

  <link name="caster_fr">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="caster_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="caster_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_fr"/>
    <origin xyz="0.125 -0.125 -0.185" rpy="0 0 0"/>
  </joint>

  <link name="caster_rl">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="caster_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="caster_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rl"/>
    <origin xyz="-0.125 0.125 -0.185" rpy="0 0 0"/>
  </joint>

  <link name="caster_rr">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
      <material name="caster_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="caster_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rr"/>
    <origin xyz="-0.125 -0.125 -0.185" rpy="0 0 0"/>
  </joint>

</robot>