  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#generatesTask">
  <rdfs:domain rdf:resource="#DetectionEvent"/>
  <rdfs:range rdf:resource="#Task"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#observedIn">
