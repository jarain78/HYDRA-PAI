<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.example.org/home"
         xmlns="http://www.example.org/home#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://www.example.org/home">
  <rdfs:comment xml:lang="en">Extended home ontology for Physical AI, Hydra-AIP, Cosmos Reasoner2, symbolic planning, robotic navigation, and dynamic insertion of unknown detections.</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#locatedIn">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Current room where an object is physically located.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#canBePickedBy">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Robot"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targetLocation">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#appliesTo">
  <rdfs:domain rdf:resource="#Task"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#containsObject">
  <rdfs:domain rdf:resource="#Room"/>
  <rdfs:range rdf:resource="#Object"/>
  <owl:inverseOf rdf:resource="#locatedIn"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRoom">
  <rdfs:domain rdf:resource="#Robot"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#connectedTo">
  <rdfs:domain rdf:resource="#Room"/>
  <rdfs:range rdf:resource="#Room"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#adjacentTo">
  <rdfs:domain rdf:resource="#Room"/>
  <rdfs:range rdf:resource="#Room"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasZone">
  <rdfs:domain rdf:resource="#Room"/>
  <rdfs:range rdf:resource="#Zone"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#zoneInRoom">
  <rdfs:domain rdf:resource="#Zone"/>
  <rdfs:range rdf:resource="#Room"/>
  <owl:inverseOf rdf:resource="#hasZone"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#locatedOnZone">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Zone"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#onTopOf">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#insideOf">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#nearTo">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Object"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#expectedRoom">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#characteristicObjectOf">
  <rdfs:domain rdf:resource="#Object"/>
  <rdfs:range rdf:resource="#Room"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#canManipulate">
  <rdfs:domain rdf:resource="#Robot"/>
  <rdfs:range rdf:resource="#Object"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#canLocate">
  <rdfs:domain rdf:resource="#Robot"/>
